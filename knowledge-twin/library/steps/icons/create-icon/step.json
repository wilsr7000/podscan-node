{
  "name": "Create Icon",
  "label": "Create Icon",
  "description": "Generate SVG step icons from mathematical sacred-geometry patterns or via LLM prompt. Returns the SVG string and metadata for use as a custom step icon.",
  "version": "1.0.0",
  "kind": "api",
  "icon": "palette",
  "iconPattern": "mandala",
  "iconPatternOptions": { "spokes": 12, "rings": 3 },
  "shape": "circle",
  "size": "small",
  "service": "Icon Generator",
  "categories": [
    "Pre-release",
    "Utilities",
    "Icons"
  ],
  "modules": [],
  "inputs": [
    {
      "variable": "mode",
      "label": "Generation mode",
      "type": "select",
      "required": true,
      "default": "`pattern`",
      "options": ["pattern", "llm"],
      "helpText": "\"pattern\" uses mathematical generators; \"llm\" sends a prompt to an LLM for custom SVG."
    },
    {
      "variable": "pattern",
      "label": "Pattern name",
      "type": "select",
      "default": "`mandala`",
      "options": [
        "",
        "anchor",
        "antenna",
        "asterisk",
        "atom",
        "bar-chart",
        "bell",
        "bluetooth",
        "borromean-rings",
        "broadcast",
        "celtic-knot",
        "chain-link",
        "chat-bubble",
        "chevron",
        "circuit",
        "cloud",
        "compass-rose",
        "concentric-circles",
        "cpu",
        "crescent-moon",
        "cross",
        "crosshair",
        "crown",
        "crystal-gem",
        "cube",
        "database",
        "diamond",
        "dna",
        "dodecagon",
        "droplet",
        "enneagram",
        "envelope",
        "eye-iris",
        "eye-of-providence",
        "fibonacci",
        "filter",
        "flame",
        "flow-branch",
        "flower-of-life",
        "funnel",
        "gear",
        "golden-spiral",
        "heart",
        "heptagram",
        "hexagon-grid",
        "hexagram",
        "hourglass",
        "infinity",
        "key",
        "labyrinth",
        "leaf",
        "lightning",
        "line-graph",
        "lock",
        "lotus",
        "magnet",
        "mandala",
        "matrix-grid",
        "megaphone",
        "merge-arrows",
        "merkaba",
        "metatrons-cube",
        "mountain",
        "nested-polygons",
        "octagon",
        "oscilloscope",
        "pentacle",
        "pentagon",
        "phone",
        "pie-chart",
        "platonic-icosa",
        "prism",
        "pulse",
        "pyramid",
        "satellite",
        "scatter-plot",
        "seed-of-life",
        "server",
        "share-node",
        "shield",
        "signal-bars",
        "snowflake",
        "sort-arrows",
        "spiral",
        "sri-yantra",
        "star-polygon",
        "star-tetrahedron",
        "sun-rays",
        "sunburst",
        "tetrahedron",
        "torus",
        "tree-of-life",
        "triangle",
        "triquetra",
        "triskelion",
        "vesica-piscis",
        "wave",
        "wifi",
        "wind-swirl",
        "yantra",
        "yin-yang"
      ],
      "helpText": "Sacred geometry or mathematical pattern to generate (mode=pattern only).",
      "renderCondition": "mode === 'pattern'"
    },
    {
      "variable": "patternOptions",
      "label": "Pattern options",
      "type": "json",
      "default": "`{}`",
      "helpText": "JSON object of pattern-specific options (e.g. {\"spokes\":12,\"rings\":3} for mandala).",
      "renderCondition": "mode === 'pattern'"
    },
    {
      "variable": "prompt",
      "label": "LLM prompt",
      "type": "textarea",
      "default": "``",
      "helpText": "Natural language description of the icon to generate (mode=llm only).",
      "renderCondition": "mode === 'llm'"
    },
    {
      "variable": "llmModel",
      "label": "LLM model",
      "type": "text",
      "default": "``",
      "helpText": "Override the default LLM model (leave blank for claude-haiku-4-5).",
      "renderCondition": "mode === 'llm'"
    }
  ],
  "exits": [
    {
      "id": "next",
      "label": "next"
    },
    {
      "id": "error",
      "label": "on error",
      "condition": "processError"
    }
  ],
  "dataOut": {
    "name": "generatedIcon",
    "type": "session",
    "ttl": 86400000
  },
  "outputExample": {
    "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 48 48\">...</svg>",
    "iconUrl": "https://cdn.jsdelivr.net/gh/wilsr7000/podscan-node@main/knowledge-twin/icons/mandala.svg",
    "mode": "pattern",
    "pattern": "mandala",
    "charCount": 842,
    "availablePatterns": ["anchor", "antenna", "...(100 patterns)...", "yin-yang"]
  },
  "iconType": "default",
  "iconUrl": ""
}
