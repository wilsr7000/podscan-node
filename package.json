{
  "name": "podscan",
  "version": "1.0.0",
  "description": "Lightweight, zero-dependency TypeScript SDK for the Podscan REST API",
  "author": "Podscan <support@podscan.fm> (https://podscan.fm)",
  "license": "MIT",
  "homepage": "https://github.com/podscan/podscan-node#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/podscan/podscan-node.git"
  },
  "bugs": {
    "url": "https://github.com/podscan/podscan-node/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "podscan",
    "podcast",
    "api",
    "sdk",
    "podcast-search",
    "podcast-api",
    "transcripts",
    "podcast-intelligence",
    "podcast-analytics",
    "brand-monitoring"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsup": "^8",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.56.0"
  }
}
